GOOGLE_API_KEY=GOOGLE_API_KEY_HERE
CEREBRAS_API_KEY=CEREBRAS_API_KEY_HERE

# Qdrant vector database (started via docker compose)
# From host / local Python: use localhost
QDRANT_HOST=localhost
